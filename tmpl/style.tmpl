<style>
:root {
  --bg:       #f9f7f4;
  --card:     #ffffff;
  --text:     #2d2a28;
  --muted:    #78716c;
  --accent:   #c75b39;
  --accent-h: #a0452a;
  --border:   #e6e0d8;
  --code-bg:  #f3efe9;
  --radius:   10px;
  --shadow:   0 1px 3px rgba(0,0,0,.06);
  --font:     -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans","PingFang SC","Microsoft YaHei",sans-serif;
  --mono:     "SF Mono","Fira Code","Fira Mono","Roboto Mono",Menlo,Courier,monospace;
  --w:        min(960px, 92%);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--font);
  background:var(--bg);
  color:var(--text);
  line-height:1.75;
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
}

/* header */
.site-header{
  background:var(--card);
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:100;
}
.header-row{
  max-width:var(--w);
  margin:0 auto;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:.75rem;
  padding:.85rem 1.5rem;
  flex-wrap:wrap;
}
.site-nav{
  display:flex;
  align-items:center;
  gap:1.25rem;
  flex-wrap:wrap;
}
.site-nav .brand{
  font-weight:700;
  font-size:1.1rem;
  color:var(--text);
  text-decoration:none;
}
.site-nav a:not(.brand){
  color:var(--muted);
  text-decoration:none;
  font-size:.9rem;
  transition:color .2s;
}
.site-nav a:not(.brand):hover{color:var(--accent)}

.search-form{
  display:flex;
  align-items:center;
}
.search-form input{
  padding:.45rem .8rem;
  border:1px solid var(--border);
  border-right:none;
  border-radius:var(--radius) 0 0 var(--radius);
  font-size:.9rem;
  font-family:var(--font);
  outline:none;
  background:var(--bg);
  color:var(--text);
  min-width:180px;
  transition:border-color .2s;
}
.search-form input:focus{border-color:var(--accent)}
.search-form button{
  padding:.45rem 1rem;
  background:var(--accent);
  color:#fff;
  border:1px solid var(--accent);
  border-radius:0 var(--radius) var(--radius) 0;
  cursor:pointer;
  font-size:.9rem;
  font-family:var(--font);
  font-weight:500;
  transition:background .2s;
}
.search-form button:hover{background:var(--accent-h);border-color:var(--accent-h)}

/* main */
main{
  max-width:var(--w);
  margin:2rem auto;
  padding:0 1.5rem;
}
.card{
  background:var(--card);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:2.5rem 2rem;
}
body>main{
  background:var(--card);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
}

/* typography */
h1,h2,h3,h4,h5,h6{margin:1.4em 0 .5em;line-height:1.35;font-weight:600;color:var(--text)}
h1{font-size:1.7rem;border-bottom:2px solid var(--border);padding-bottom:.35em}
h2{font-size:1.4rem}
h3{font-size:1.2rem}
h4{font-size:1.05rem}
p{margin:.75em 0}
a{color:var(--accent);text-decoration:none;transition:color .2s}
a:hover{color:var(--accent-h);text-decoration:underline}

img{max-width:100%;height:auto;border-radius:4px}

/* code */
code{
  font-family:var(--mono);
  background:var(--code-bg);
  padding:.15em .4em;
  border-radius:4px;
  font-size:.88em;
  color:#b23;
}
pre{
  background:var(--code-bg);
  padding:1rem 1.2rem;
  border-radius:var(--radius);
  overflow-x:auto;
  margin:1em 0;
  border:1px solid var(--border);
  line-height:1.55;
}
pre code{
  background:none;
  padding:0;
  border-radius:0;
  font-size:.85rem;
  color:var(--text);
}

/* blockquote */
blockquote{
  border-left:4px solid var(--accent);
  margin:1em 0;
  padding:.6em 1.2em;
  background:var(--code-bg);
  border-radius:0 var(--radius) var(--radius) 0;
  color:var(--muted);
}
blockquote>:first-child{margin-top:0}
blockquote>:last-child{margin-bottom:0}

/* table */
table{border-collapse:collapse;width:100%;margin:1em 0;font-size:.9rem}
th,td{border:1px solid var(--border);padding:.55em .8em;text-align:left}
th{background:var(--code-bg);font-weight:600}
tr:nth-child(even) td{background:#fdfcf9}

/* hr */
hr{border:none;border-top:1px solid var(--border);margin:1.8rem 0}

/* footer */
.site-footer{
  text-align:center;
  padding:1.5rem;
  color:var(--muted);
  font-size:.85rem;
  max-width:var(--w);
  margin:0 auto;
}

/* blog index list */
.blog-index{list-style:none}
.blog-index li{padding:.4rem 0;border-bottom:1px solid var(--border)}
.blog-index li:last-child{border-bottom:none}
.blog-index a{font-size:.98rem;display:block;padding:.25rem 0}

/* back-link */
.back-link{
  display:inline-flex;align-items:center;gap:.3rem;
  margin-bottom:1.5rem;color:var(--muted);font-size:.9rem;
}
.back-link:hover{color:var(--accent);text-decoration:none}

/* search results */
.search-result{margin:.6rem 0;line-height:1.6}
.search-result a{font-size:1rem}

/* responsive */
@media(max-width:640px){
  .header-row{flex-direction:column;align-items:stretch}
  .search-form input{min-width:0;flex:1}
  main{margin:1rem auto;padding:0 .75rem}
  .card{padding:1.5rem 1rem}
  h1{font-size:1.4rem}
}
</style>
